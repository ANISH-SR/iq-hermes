# Solana Configuration
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY
# Or use QuickNode, Alchemy, or any Solana RPC

# Wallet Private Key (base58 encoded)
# WARNING: Keep this secure! Never commit to git!
SOLANA_PRIVATE_KEY=your_base58_private_key_here

# Optional: Encryption key for private skills
# Set this if you want to encrypt skills before upload
SKILL_ENCRYPTION_KEY=your-secret-encryption-key
